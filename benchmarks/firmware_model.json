{
  "$schema": "https://raw.githubusercontent.com/sandialabs/ctadl-rs/refs/heads/main/ctadl-ascent/src/models/ctadl-model-generator.schema.json",
  "model_generators": [
    {
      "find": "methods",
      "where": [
        {
          "constraint": "signature_pattern",
          "pattern": ".*(fgets|fgetws|gets|getws|recv|fscanf|fwscanf|getenv|read|fread|msgrcv).*"
        }
      ],
      "model": {
        "sources": [
          { "port": "Return", "kind": "user_input" },
          { "port": "Argument(0)", "kind": "user_input" }
        ]
      }
    },
    {
      "find": "methods",
      "where": [
        {
          "constraint": "signature_pattern",
          "pattern": ".*(system|popen|execl|execlp|execv|execvp|execle|execve).*"
        }
      ],
      "model": {
        "sinks": [
          { "port": "Argument(0)", "kind": "command_injection" }
        ]
      }
    },
    {
      "find": "methods",
      "where": [
        {
          "constraint": "signature_pattern",
          "pattern": ".*(strcpy|wcscpy|strcat|wcscat|sprintf|swprintf).*"
        }
      ],
      "model": {
        "sinks": [
          { "port": "Argument(1)", "kind": "buffer_overflow" }
        ]
      }
    }
  ]
}
